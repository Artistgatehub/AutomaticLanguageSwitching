{
  "manifest_version": 3,
  "name": "Automatic Language Switching",
  "version": "0.2.1",
  "key": "",
  "description": "Restores an assigned keyboard layout when the active Chrome tab changes.",
  "icons": {
    "16": "icons/icon-inactive-16.png",
    "32": "icons/icon-inactive-32.png",
    "48": "icons/icon-inactive-48.png",
    "128": "icons/icon-inactive-128.png"
  },
  "permissions": [
    "tabs",
    "nativeMessaging"
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon-inactive-16.png",
      "32": "icons/icon-inactive-32.png",
      "48": "icons/icon-inactive-48.png",
      "128": "icons/icon-inactive-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["dist/focus-return.js"],
      "run_at": "document_start"
    }
  ],
  "background": {
    "service_worker": "dist/service-worker.js",
    "type": "module"
  }
}
